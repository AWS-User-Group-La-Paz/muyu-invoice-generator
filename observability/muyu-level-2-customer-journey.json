{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "12.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "text",
      "name": "Text",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Accepted valid invoice-generation requests over the selected time range. Target: 99%.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "sum(increase(muyu_invoice_generation_requests_total{outcome=\"accepted\"}[$__range])) / clamp_min(sum(increase(muyu_invoice_generation_requests_total{outcome=~\"accepted|save_failed|enqueue_failed\"}[$__range])), 1)",
          "instant": true,
          "legendFormat": "Acceptance SLI",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Invoice acceptance SLI (target: 99%)",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Completed jobs divided by completed and failed jobs over the selected time range. Target: 99%.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "sum(increase(muyu_invoice_jobs_finished_total{outcome=\"completed\"}[$__range])) / clamp_min(sum(increase(muyu_invoice_jobs_finished_total{outcome=~\"completed|failed\"}[$__range])), 1)",
          "instant": true,
          "legendFormat": "Completion SLI",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Worker completion SLI (target: 99%)",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "P95 duration for successfully completed worker jobs. Use it to establish a baseline before setting a latency SLO.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisLabel": "seconds",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(muyu_invoice_job_duration_seconds_bucket{outcome=\"completed\"}[$__rate_interval])))",
          "legendFormat": "P95 completed job duration",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Completed-job P95 duration",
      "type": "timeseries"
    },
    {
      "description": "Add the collected AWS/SQS queue-depth and oldest-message-age metrics after confirming their metric names in Grafana Explore. This repository does not define the collector mapping.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "## Queue health\n\nAdd the AWS/SQS queue-depth and oldest-message-age metrics after confirming their names in Grafana Explore.\n\nDo not set a queue-age target until participants have observed a baseline.",
        "mode": "markdown"
      },
      "title": "Queue health setup",
      "transparent": false,
      "type": "text"
    }
  ],
  "preload": false,
  "refresh": "5m",
  "schemaVersion": 42,
  "tags": [
    "muyu",
    "sre-training",
    "level-2"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Muyu / L2 — Customer Journey & SLOs",
