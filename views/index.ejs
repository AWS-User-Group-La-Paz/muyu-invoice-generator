<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Muyu: Invoice Generator</title>
	<link rel="stylesheet" href="/css/main.css">
	<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
	<script>
		function getCookie(name) {
			const row = document.cookie
				.split("; ")
				.find((part) => part.startsWith(`${name}=`));
			return row ? decodeURIComponent(row.slice(name.length + 1)) : "";
		}

			function setCookie(name, value, days = 30) {
				const expires = new Date(Date.now() + days * 864e5).toUTCString();
				document.cookie = `${name}=${encodeURIComponent(value)}; expires=${expires}; path=/; SameSite=Lax`;
			}

		function invoiceForm(profile) {
			return {
				companyName: profile.companyName || "",
				companyDetails: profile.companyDetails || "",
				taxRate: profile.taxRate || "",
				expenses: [{ id: 1, description: "", cost: "" }],
				nextId: 2,
				generated: false,
				addExpense() {
					this.expenses.push({ id: this.nextId++, description: "", cost: "" });
				},
				removeExpense(id) {
					if (this.expenses.length > 1) {
						this.expenses = this.expenses.filter((expense) => expense.id !== id);
					}
				},
				get subtotal() {
					return this.expenses.reduce((sum, expense) => sum + (parseFloat(expense.cost) || 0), 0);
				},
				get taxAmount() {
					return (this.subtotal * (parseFloat(this.taxRate) || 0)) / 100;
				},
				get total() {
					return this.subtotal + this.taxAmount;
				},
				resetExpenses() {
					this.expenses = [{ id: this.nextId++, description: "", cost: "" }];
				},
				showGenerated() {
					this.generated = true;
					window.scrollTo(0, 0);
					setTimeout(() => this.resetExpenses(), 0);
				},
			};
		}

		if (getCookie("user_email")) {
			document.documentElement.classList.add("has-cookie");
		}
	</script>
</head>
	<body
		x-data="{
			userEmail: getCookie('user_email'),
			showModal: !getCookie('user_email'),
			email: getCookie('user_email'),
			submitEmail() {
				const email = this.email.trim();
				if (email) {
					this.email = email;
					this.userEmail = email;
					setCookie('user_email', email);
					this.showModal = false;
				}
			}
		}"
		:class="{ locked: showModal }"
	>
		<dialog
			id="email-modal"
			class="modal"
			x-init="$nextTick(() => showModal && $el.showModal())"
			x-effect="showModal ? ($el.open || $el.showModal()) : ($el.open && $el.close())"
			@cancel.prevent
			x-cloak
		>
			<form class="dialog" @submit.prevent="submitEmail">
				<h1>Welcome to Muyu</h1>
				<p>Please enter your email to start generating and tracking invoices.</p>
				<label for="userEmail">Email Address</label>
				<input id="userEmail" type="email" x-model="email" placeholder="your@email.com" autocomplete="email" inputmode="email" autofocus required>
				<button type="submit">Start Generating</button>
			</form>
		</dialog>

	<div
		class="shell"
		x-data='invoiceForm(<%= JSON.stringify({
			companyName: profile ? profile.company_name : "",
			companyDetails: profile ? profile.company_details : "",
			taxRate: profile ? profile.default_tax_rate : ""
		}) %>)'
	>
		<aside class="sidebar">
			<header>Muyu: Invoice Generator</header>
			<nav>
				<a class="active" href="/">Create Invoice</a>
				<a href="/past-invoices">Past Invoices</a>
				<a href="/settings">Settings</a>
			</nav>
			<footer x-text="userEmail ? `Logged in as: ${userEmail}` : 'Invoice Gen'"></footer>
		</aside>

			<main>
				<section class="page-header">
					<div>
						<p class="kicker">Invoice workbench</p>
						<h1>Create New Invoice</h1>
						<p>Enter the client details, add expenses, and generate a PDF invoice from this draft.</p>
					</div>
					<div class="header-meter" aria-live="polite">
						<span>Draft total</span>
						<strong x-text="'$' + total.toFixed(2)">$0.00</strong>
					</div>
				</section>

				<div class="notice" x-show="generated" x-cloak role="status">
					<span>Invoice generated. Your download should start shortly.</span>
				</div>

				<form class="workspace-grid" action="/generate" method="POST" @submit="showGenerated($el)">
					<div class="form-stack">
						<fieldset class="panel">
							<legend>Company Information</legend>
							<p class="panel-note">These fields appear on the generated invoice.</p>
							<div class="field-grid">
								<label for="companyName">
									Company Name
									<input id="companyName" name="companyName" x-model="companyName" placeholder="Ridgeline Studio" required>
								</label>

								<label class="wide" for="companyDetails">
									Company Details
									<textarea id="companyDetails" name="companyDetails" x-model="companyDetails" placeholder="Address, contact details, tax ID" required></textarea>
								</label>
							</div>
						</fieldset>

						<fieldset class="panel">
							<legend>Expenses</legend>
							<div class="split">
								<p class="panel-note">Each row becomes one invoice line item.</p>
								<button type="button" class="secondary" @click="addExpense">Add Expense</button>
							</div>

							<div class="expense-list">
								<template x-for="(expense, index) in expenses" :key="expense.id">
									<div class="expense-row">
										<label>
											Description
											<input type="text" :name="'expenses[' + index + '][description]'" x-model="expense.description" placeholder="Design retainer" required>
										</label>
										<label>
											Cost
											<input type="number" step="0.01" min="0" :name="'expenses[' + index + '][cost]'" x-model="expense.cost" placeholder="0.00" required>
										</label>
										<button type="button" class="danger" @click="removeExpense(expense.id)" :disabled="expenses.length === 1">Remove</button>
									</div>
								</template>
							</div>
						</fieldset>

						<fieldset class="panel">
							<legend>Tax Information</legend>
							<p class="panel-note">Use the default from Settings or override it for this invoice.</p>
							<label class="short" for="taxRate">
								Tax Rate (%)
								<input id="taxRate" name="taxRate" type="number" step="0.01" min="0" max="100" x-model="taxRate" placeholder="0.00" required>
							</label>
						</fieldset>
					</div>

					<aside class="ledger-panel" aria-label="Invoice total">
						<p class="kicker">Live ledger</p>
						<h2>Invoice Summary</h2>
						<section class="summary">
							<p><span>Subtotal</span><strong x-text="'$' + subtotal.toFixed(2)">$0.00</strong></p>
							<p><span x-text="'Tax (' + (taxRate || 0) + '%)'">Tax (0%)</span><strong x-text="'$' + taxAmount.toFixed(2)">$0.00</strong></p>
							<p class="total"><span>Total</span><strong x-text="'$' + total.toFixed(2)">$0.00</strong></p>
						</section>

						<div class="ledger-actions">
							<button type="submit">Generate Invoice</button>
							<span class="field-hint">PDF downloads after save</span>
						</div>
					</aside>
				</form>
			</main>
	</div>
</body>
</html>
