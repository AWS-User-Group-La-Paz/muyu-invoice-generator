<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Muyu: Invoice Generator</title>
	<link rel="stylesheet" href="/css/main.css">
	<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
	<script>
		function getCookie(name) {
			const row = document.cookie
				.split("; ")
				.find((part) => part.startsWith(`${name}=`));
			return row ? decodeURIComponent(row.slice(name.length + 1)) : "";
		}

		function setCookie(name, value, days = 30) {
			const expires = new Date(Date.now() + days * 864e5).toUTCString();
			document.cookie = `${name}=${encodeURIComponent(value)}; expires=${expires}; path=/`;
		}

		function invoiceForm(profile) {
			return {
				companyName: profile.companyName || "",
				companyDetails: profile.companyDetails || "",
				taxRate: profile.taxRate || "",
				expenses: [{ id: 1, description: "", cost: "" }],
				nextId: 2,
				generated: false,
				addExpense() {
					this.expenses.push({ id: this.nextId++, description: "", cost: "" });
				},
				removeExpense(id) {
					if (this.expenses.length > 1) {
						this.expenses = this.expenses.filter((expense) => expense.id !== id);
					}
				},
				get subtotal() {
					return this.expenses.reduce((sum, expense) => sum + (parseFloat(expense.cost) || 0), 0);
				},
				get taxAmount() {
					return (this.subtotal * (parseFloat(this.taxRate) || 0)) / 100;
				},
				get total() {
					return this.subtotal + this.taxAmount;
				},
				resetExpenses() {
					this.expenses = [{ id: this.nextId++, description: "", cost: "" }];
				},
				showGenerated() {
					this.generated = true;
					window.scrollTo(0, 0);
					setTimeout(() => this.resetExpenses(), 0);
				},
			};
		}

		if (getCookie("user_email")) {
			document.documentElement.classList.add("has-cookie");
		}
	</script>
</head>
<body
	x-data="{
		showModal: !getCookie('user_email'),
		email: '',
		submitEmail() {
			if (this.email) {
				setCookie('user_email', this.email);
				this.showModal = false;
				window.location.reload();
			}
		}
	}"
	:class="{ locked: showModal }"
>
	<div id="email-modal" class="modal" x-show="showModal" x-cloak>
		<form class="dialog" @submit.prevent="submitEmail">
			<h1>Welcome to Muyu</h1>
			<p>Please enter your email to start generating and tracking invoices.</p>
			<label for="userEmail">Email Address</label>
			<input id="userEmail" type="email" x-model="email" placeholder="your@email.com" required>
			<button type="submit">Start Generating</button>
		</form>
	</div>

	<div
		class="shell"
		x-data='invoiceForm(<%= JSON.stringify({
			companyName: profile ? profile.company_name : "",
			companyDetails: profile ? profile.company_details : "",
			taxRate: profile ? profile.default_tax_rate : ""
		}) %>)'
	>
		<aside class="sidebar">
			<header>Muyu: Invoice Generator</header>
			<nav>
				<a class="active" href="/">Create Invoice</a>
				<a href="/past-invoices">Past Invoices</a>
				<a href="/settings">Settings</a>
			</nav>
			<footer x-text="getCookie('user_email') ? `Logged in as: ${getCookie('user_email')}` : 'Invoice Gen'"></footer>
		</aside>

		<main>
			<section class="page-header">
				<h1>Create New Invoice</h1>
				<p>Fill in the details below to generate your invoice</p>
			</section>

			<div class="notice" x-show="generated" x-cloak>
				<span>Invoice generated. Your download should start shortly.</span>
			</div>

			<form class="panel" action="/generate" method="POST" @submit="showGenerated($el)">
				<fieldset>
					<legend>Company Information</legend>
					<label for="companyName">Company Name</label>
					<input id="companyName" name="companyName" x-model="companyName" placeholder="Enter company name" required>

					<label for="companyDetails">Company Details</label>
					<textarea id="companyDetails" name="companyDetails" x-model="companyDetails" placeholder="Enter company address, contact info, etc." required></textarea>
				</fieldset>

				<fieldset>
					<div class="split">
						<legend>Expenses</legend>
						<button type="button" @click="addExpense">Add Expense</button>
					</div>

					<template x-for="(expense, index) in expenses" :key="expense.id">
						<div class="expense-row">
							<label>
								Description
								<input type="text" :name="'expenses[' + index + '][description]'" x-model="expense.description" placeholder="Item description" required>
							</label>
							<label>
								Cost
								<input type="number" step="0.01" min="0" :name="'expenses[' + index + '][cost]'" x-model="expense.cost" placeholder="0.00" required>
							</label>
							<button type="button" class="danger" @click="removeExpense(expense.id)" :disabled="expenses.length === 1">Remove</button>
						</div>
					</template>
				</fieldset>

				<fieldset>
					<legend>Tax Information</legend>
					<label for="taxRate">Tax Rate (%)</label>
					<input class="short" id="taxRate" name="taxRate" type="number" step="0.01" min="0" max="100" x-model="taxRate" placeholder="0.00" required>
				</fieldset>

				<section class="summary">
					<p><span>Subtotal</span><strong x-text="'$' + subtotal.toFixed(2)"></strong></p>
					<p><span x-text="'Tax (' + (taxRate || 0) + '%)'"></span><strong x-text="'$' + taxAmount.toFixed(2)"></strong></p>
					<p class="total"><span>Total</span><strong x-text="'$' + total.toFixed(2)"></strong></p>
				</section>

				<div class="actions">
					<button type="submit">Generate Invoice</button>
				</div>
			</form>
		</main>
	</div>
</body>
</html>
