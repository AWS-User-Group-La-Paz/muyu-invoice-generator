<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Settings - Muyu</title>
	<link rel="stylesheet" href="/css/main.css">
	<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
</head>
<body>
	<div class="shell">
		<aside class="sidebar">
			<header>Muyu: Invoice Generator</header>
			<nav>
				<a href="/">Create Invoice</a>
				<a href="/past-invoices">Past Invoices</a>
				<a class="active" href="/settings">Settings</a>
			</nav>
			<footer>Logged in as: <%= email %></footer>
		</aside>

			<main>
				<section class="page-header">
					<div>
						<p class="kicker">Defaults</p>
						<h1>Settings</h1>
						<p>Set the company details and tax rate Muyu should preload into new invoice drafts.</p>
					</div>
				</section>

				<div
					class="notice"
					x-data="{ show: new URLSearchParams(window.location.search).get('success') === '1' }"
					x-show="show"
					x-cloak
					role="status"
				>
					<span>Settings saved successfully.</span>
					<button type="button" class="link" @click="show = false; history.replaceState({}, document.title, location.pathname)">Dismiss</button>
				</div>

				<form class="workspace-grid" action="/settings" method="POST">
					<div class="form-stack">
						<fieldset class="panel">
							<legend>Company Defaults</legend>
							<p class="panel-note">Saved values appear automatically on the Create Invoice page.</p>
							<div class="field-grid">
								<label for="companyName">
									Default Company Name
									<input id="companyName" name="companyName" value="<%= profile ? profile.company_name : '' %>" placeholder="Ridgeline Studio">
								</label>

								<label class="wide" for="companyDetails">
									Default Company Details
									<textarea id="companyDetails" name="companyDetails" placeholder="Address, contact details, tax ID"><%= profile ? profile.company_details : '' %></textarea>
								</label>

								<label class="short" for="taxRate">
									Default Tax Rate (%)
									<input id="taxRate" name="taxRate" type="number" step="0.01" min="0" max="100" value="<%= profile ? profile.default_tax_rate : '' %>" placeholder="0.00">
								</label>
							</div>
						</fieldset>
					</div>

					<aside class="ledger-panel">
						<p class="kicker">Profile</p>
						<h2>Saved Preset</h2>
						<p class="panel-note">Keep this short and invoice-ready. You can still override every field on an individual invoice.</p>
						<div class="ledger-actions">
							<button type="submit">Save Settings</button>
						</div>
					</aside>
				</form>
			</main>
	</div>
</body>
</html>
