<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Settings - Muyu</title>
	<link rel="stylesheet" href="/css/main.css">
	<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
</head>
<body>
	<div class="shell">
		<aside class="sidebar">
			<header>Muyu: Invoice Generator</header>
			<nav>
				<a href="/">Create Invoice</a>
				<a href="/past-invoices">Past Invoices</a>
				<a class="active" href="/settings">Settings</a>
			</nav>
			<footer>Logged in as: <%= email %></footer>
		</aside>

		<main>
			<section class="page-header">
				<h1>Settings</h1>
				<p>Manage your default company information and preferences</p>
			</section>

			<div
				class="notice"
				x-data="{ show: new URLSearchParams(window.location.search).get('success') === '1' }"
				x-show="show"
				x-cloak
			>
				<span>Settings saved successfully.</span>
				<button type="button" class="link" @click="show = false; history.replaceState({}, document.title, location.pathname)">Dismiss</button>
			</div>

			<form class="panel" action="/settings" method="POST">
				<fieldset>
					<label for="companyName">Default Company Name</label>
					<input id="companyName" name="companyName" value="<%= profile ? profile.company_name : '' %>" placeholder="Enter default company name">

					<label for="companyDetails">Default Company Details</label>
					<textarea id="companyDetails" name="companyDetails" placeholder="Enter default company address, contact info, etc."><%= profile ? profile.company_details : '' %></textarea>

					<label for="taxRate">Default Tax Rate (%)</label>
					<input class="short" id="taxRate" name="taxRate" type="number" step="0.01" min="0" max="100" value="<%= profile ? profile.default_tax_rate : '' %>" placeholder="0.00">
				</fieldset>

				<div class="actions">
					<button type="submit">Save Settings</button>
				</div>
			</form>
		</main>
	</div>
</body>
</html>
