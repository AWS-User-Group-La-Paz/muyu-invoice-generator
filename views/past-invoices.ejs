<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Past Invoices - Muyu</title>
	<link rel="stylesheet" href="/css/main.css">
</head>
<body>
	<div class="shell">
		<aside class="sidebar">
			<header>Muyu: Invoice Generator</header>
			<nav>
				<a href="/">Create Invoice</a>
				<a class="active" href="/past-invoices">Past Invoices</a>
				<a href="/settings">Settings</a>
			</nav>
			<footer>Logged in as: <%= email %></footer>
		</aside>

			<main>
				<section class="page-header">
					<div>
						<p class="kicker">Ledger</p>
						<h1>Past Invoices</h1>
						<p>Review previously generated invoices and download a fresh PDF when you need it.</p>
					</div>
				</section>

				<section class="invoice-table-wrap" aria-label="Past invoices">
					<table class="invoice-table">
						<thead>
							<tr>
								<th>Date</th>
								<th>Company</th>
								<th class="number">Total</th>
								<th>Action</th>
							</tr>
						</thead>
						<tbody>
							<% if (invoices.length === 0) { %>
								<tr>
									<td colspan="4" class="empty">No invoices found for this email.</td>
								</tr>
							<% } else { %>
								<% invoices.forEach(invoice => { %>
									<tr>
										<td data-label="Date"><%= new Date(invoice.created_at).toLocaleDateString() %></td>
										<td data-label="Company"><%= invoice.company_name %></td>
										<td data-label="Total" class="number">$<%= parseFloat(invoice.total).toFixed(2) %></td>
										<td data-label="Action"><a class="button secondary" href="/download/<%= invoice.id %>">Download</a></td>
									</tr>
								<% }) %>
							<% } %>
						</tbody>
					</table>
				</section>
			</main>
	</div>
</body>
</html>
